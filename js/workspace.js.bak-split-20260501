    zona: null,       // GeoJSON completo
    zonaGEE: null,    // GeoJSON simplificado
    zonaNombre: 'Mi zona de estudio',
    zonaHa: 0,
    zonaId: null,     // UUID del workspace en Supabase
    capasActivas: {},
    resultados: {}    // Cache de análisis: key = 'tipo_indice' (sin tilesUrl — expiran)
